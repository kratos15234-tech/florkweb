<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>$FLORK – OG EDITION</title>
  <link href="https://fonts.googleapis.com/css2?family=Lilita+One&family=Roboto:wght@400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #ffffff;
      --text: #111111;
      --stat-bg: #f5f5f5;
      --btn-bg: #111111;
      --btn-text: #ffffff;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body, html { height: 100%; width: 100%; overflow: hidden; background: var(--bg); font-family: 'Roboto', sans-serif; color: var(--text); }

    /* ANIMATED GRID WITH GRADIENT */
    .grid {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background-image: 
        linear-gradient(to right, transparent 49px, #ddd 49px, #ddd 50px, transparent 50px),
        linear-gradient(to bottom, transparent 49px, #ddd 49px, #ddd 50px, transparent 50px);
      background-size: 50px 50px;
      z-index: 0;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,1), rgba(0,0,0,0.3));
    }

    .grid::before {
      content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background: linear-gradient(90deg, #8b5cf6, #60a5fa, #2dd4bf);
      background-size: 300% 300%;
      mix-blend-mode: screen;
      animation: gradientMove 8s ease infinite;
      z-index: -1;
    }

    @keyframes gradientMove {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    nav {
      position: relative; z-index: 100; display: flex; align-items: center; justify-content: space-between;
      padding: 15px 30px; background: rgba(255, 255, 255, 0.8); border-bottom: 2px solid #eee;
    }
    
    /* GRADIENT LOGO STYLE */
    .logo {
      display: flex; align-items: center; gap: 10px;
    }
    .logo-gradient-text {
      font-family: 'Lilita One', cursive;
      font-size: 2rem;
      background: linear-gradient(90deg, #ac44ff 0%, #6ec2ff 50%, #44e8ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent; /* Keep the interior gradient-colored */
      -webkit-text-stroke: 1px #111; /* Add outline like the image */
      letter-spacing: 1px;
    }
    .logo img {
      width: 40px;
      border-radius: 0;
    }
    
    .nav-right { display: flex; align-items: center; gap: 10px; }

    .btn-x-comm {
      display: flex; align-items: center; justify-content: center;
      background: var(--btn-bg); color: var(--bg);
      width: 38px; height: 38px; text-decoration: none;
      font-size: 1.2rem; border-radius: 0; transition: 0.2s;
    }
    .btn-x-comm:hover { opacity: 0.8; }

    .price-pill { 
        background: var(--stat-bg); padding: 8px 15px; border: 1px solid #ddd;
        font-weight: bold; font-size: 0.9rem; letter-spacing: 0.05em; border-radius: 0;
    }
    #m5-change { margin-left: 10px; padding: 2px 6px; }
    .up { color: #10b981; } .down { color: #ef4444; }

    .main-stage { position: relative; height: calc(100vh - 70px); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10; }
    
    .hero-title { 
      font-family: 'Lilita One', cursive; 
      font-size: clamp(3.5rem, 16vw, 11rem); 
      line-height: 0.95; 
      text-align: center;
      color: var(--text);
      text-transform: uppercase;
      text-shadow: 4px 4px 0px #eee, 8px 8px 0px #ddd;
    }
    .outline { 
      -webkit-text-stroke: 2px var(--text); 
      color: transparent; 
      text-shadow: none;
    }

    .hero-description {
      margin-top: 25px;
      font-size: 1.15rem;
      max-width: 750px;
      line-height: 1.5;
      font-weight: 700;
      color: #333;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .ca-line {
      margin-top: 10px;
      font-family: monospace;
      background: #f0f0f0;
      padding: 5px 15px;
      font-size: 0.9rem;
      border: 1px solid #ddd;
      color: #555;
    }

    .btn-buy-main {
      margin-top: 35px; padding: 15px 60px; background: var(--btn-bg); color: var(--btn-text);
      font-family: 'Lilita One', cursive; font-size: 1.8rem;
      text-decoration: none; transition: 0.2s; border-radius: 0;
      box-shadow: 6px 6px 0px #ddd;
      position: relative;
      z-index: 9999;
    }
    .btn-buy-main:hover { transform: translate(-2px, -2px); box-shadow: 10px 10px 0px #ccc; }

    .particle { position: absolute; pointer-events: none; z-index: 5; animation: explode_prolonged 7s forwards cubic-bezier(0, 0.5, 0.5, 1); opacity: 0; }
    .particle img { width: 100%; height: auto; border: 1px solid #ddd; background: #fff; border-radius: 0; }

    @keyframes explode_prolonged {
      0% { transform: translate(0, 0) scale(0) rotate(0deg); opacity: 0; }
      5% { opacity: 1; } 
      30% { transform: translate(var(--tx), var(--ty)) scale(var(--s)) rotate(var(--r)); opacity: 1; }
      80% { opacity: 1; }
      100% { transform: translate(var(--tx), var(--ty)) scale(var(--s)) rotate(var(--r)); opacity: 0; }
    }
  </style>
</head>
<body>

<div class="grid"></div>

<nav>
  <div class="logo">
    <img src="logo.png" onerror="this.src='https://via.placeholder.com/40'">
    <span class="logo-gradient-text">$FLORK</span>
  </div>
  <div class="nav-right">
    <a href="https://x.com/i/communities/2004950470960316605" target="_blank" class="btn-x-comm" title="X Community">𝕏</a>
    <div class="price-pill">
      MCAP: <span id="mcap-val">...</span> | 5M: <span id="m5-change">0.00%</span>
    </div>
  </div>
</nav>

<main class="main-stage" id="stage">
  <h1 class="hero-title">
    <span class="outline">OG</span><br>
    FLORK<br>
    <span class="outline">ON SOL</span>
  </h1>
  
  <p class="hero-description">
    X app updating to custom timelines. In the custom timelines there is a "meme" section.<br>
    The image icon for it is FLORK. This token is the OG FLORK on SOL chain.
  </p>

  <div class="ca-line">
    CA : Ar3QbizYS8tGysqqEmeBu66Ga5snYFnRE5JhaxjRgGS
  </div>

  <a href="https://dexscreener.com/solana/Ar3QbizYS8tGysqqEmeBu66Ga5snYFnRE5JhaxjRgGS" target="_blank" class="btn-buy-main">BUY $FLORK</a>
</main>

<script>
  const totalImages = 36;
  const stage = document.getElementById('stage');

  function createExplosion() {
    for(let i=0; i<6; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const imgNum = Math.floor(Math.random() * totalImages) + 1;
      const size = Math.random() * 100 + 70;
      p.style.width = size + 'px';
      const tx = (Math.random() - 0.5) * 1400;
      const ty = (Math.random() - 0.5) * 900;
      const r = (Math.random() - 0.5) * 720;
      const s = Math.random() * 1.3 + 0.3;
      p.style.setProperty('--tx', `${tx}px`);
      p.style.setProperty('--ty', `${ty}px`);
      p.style.setProperty('--r', `${r}deg`);
      p.style.setProperty('--s', s);
      p.innerHTML = `<img src="img${imgNum}.png" onerror="this.src='https://via.placeholder.com/150'">`;
      stage.appendChild(p);
      setTimeout(() => p.remove(), 7500);
    }
  }

  setInterval(createExplosion, 2000);
  createExplosion();

  async function getStats() {
    try {
      const r = await fetch('https://api.dexscreener.com/latest/dex/tokens/Ar3QbizYS8tGysqqEmeBu66Ga5snYFnRE5JhaxjRgGS?nocache=' + Date.now());
      const d = await r.json();
      const p = d.pairs?.[0];
      if(p) {
        const mc = p.marketCap || p.fdv;
        const mcapVal = document.getElementById('mcap-val');
        if (mc >= 1000000) {
            mcapVal.textContent = (mc / 1000000).toFixed(3) + 'M';
        } else {
            mcapVal.textContent = (mc / 1000).toFixed(1) + 'K';
        }
        const m5 = p.priceChange?.m5 || 0;
        const m5El = document.getElementById('m5-change');
        m5El.textContent = (m5 >= 0 ? '+' : '') + m5 + '%';
        m5El.className = m5 >= 0 ? 'up' : 'down';
      }
    } catch(e){}
  }
  getStats();
  setInterval(getStats, 5000);
</script>

</body>
</html>